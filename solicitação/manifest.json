{
  "manifest_version": 3,
  "name": "Solicitar Ativos — Magalu",
  "version": "3.0",
  "description": "Automatiza solicitações em lote no Gestão de Ativos",
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": ["https://gestaoativos.magazineluiza.com.br/*"],
      "js": ["injector.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://gestaoativos.magazineluiza.com.br/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}