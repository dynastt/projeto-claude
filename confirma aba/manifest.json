  "name": "Confirma ABA — Magalu",
  "version": "1.0.0",
  "description": "Confirmação de envios ABA entre CDs — Gestão de Ativos Magalu",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["https://gestaoativos.magazineluiza.com.br/*"],
